-- AUTO-SETUP DE HABILIDADES (Q=Damage, E=Heal)
-- =========================================================================
local function findToolInInventory(toolName)
    local char = LocalPlayer.Character
    local backpack = LocalPlayer:FindFirstChild("Backpack")

    if char then
        for _, tool in ipairs(char:GetChildren()) do
            if tool:IsA("Tool") and tool.Name == toolName then
                return tool, char
            end
        end
    end

    if backpack then
        for _, tool in ipairs(backpack:GetChildren()) do
            if tool:IsA("Tool") and tool.Name == toolName then
                return tool, backpack
            end
        end
    end

    return nil, nil
end

local function findHealAbility()
    local char = LocalPlayer.Character
    local backpack = LocalPlayer:FindFirstChild("Backpack")

    -- Procura os heals suportados na ordem de prioridade
    for _, healName in ipairs(NightHub.SupportedHeals) do
        if char then
            for _, tool in ipairs(char:GetChildren()) do
                if tool:IsA("Tool") and tool.Name == healName then
                    return tool, char, healName
                end
            end
        end
        if backpack then
            for _, tool in ipairs(backpack:GetChildren()) do
                if tool:IsA("Tool") and tool.Name == healName then
                    return tool, backpack, healName
                end
            end
        end
    end

    return nil, nil, nil
end

local function setupAbilities()
    local char = LocalPlayer.Character
    if not char then return end

    local humanoid = char:FindFirstChild("Humanoid")
    if not humanoid then return end

    -- Espera o character estar pronto
    task.wait(1)

    -- Procura e equipa o heal para o slot E
    local healTool, parent, healName = findHealAbility()
    if healTool then
        print("[Setup] Heal encontrado: " .. healName)
        -- O heal fica no slot E (Backpack)
        -- O tool já está no inventário, só precisa de estar no slot correto
    else
        warn("[Setup] Nenhum heal suportado encontrado (Chain Heal, Life Dash, Universal Heal)")
        warn("[Setup] Healing NÃO funcionará sem um destes heals!")
    end

    -- Procura ability de dano para o slot Q
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if backpack then
        for _, tool in ipairs(backpack:GetChildren()) do
            if tool:IsA("Tool") and tool.Name ~= "Leaping Strike" then
                -- Verifica se NÃO é o heal que já encontramos
                local isHeal = false
                for _, healName in ipairs(NightHub.SupportedHeals) do
                    if tool.Name == healName then
                        isHeal = true
                        break
                    end
                end
                if not isHeal then
                    print("[Setup] Ability de dano encontrada: " .. tool.Name)
                    break
                end
            end
        end
    end

    print("[Setup] Layout correto: Q = Damage Spell | E = Healing Spell")
end

