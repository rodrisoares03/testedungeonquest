function UpdateUIToggle(toggleKey, state)
    local toggleData = UIToggles[toggleKey]
    if not toggleData then return end
    
    local targetColor = state and Cores.SwitchOn or Cores.SwitchOff
    local targetPos = state and UDim2.new(1, -18, 0.5, -8) or UDim2.new(0, 2, 0.5, -8)
    
    pcall(function()
        TweenService:Create(toggleData.SwitchBg, TweenInfo.new(0.2), {
            BackgroundColor3 = targetColor
        }):Play()
        
        TweenService:Create(toggleData.SwitchKnob, TweenInfo.new(0.2), {
            Position = targetPos
        }):Play()
    end)
end

