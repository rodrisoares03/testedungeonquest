local ZoneChunkSize = 50

local function getZoneKey(pos)
    return math.floor(pos.Z / ZoneChunkSize)
end

local function getAllAliveNPCs(char)
    local npcs = {}
    local charRoot = char and char:FindFirstChild("HumanoidRootPart")
    local maxRange = NightHub.MaxDetectionRange
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Model") and v ~= char then
            local hum = v:FindFirstChild("Humanoid")
            local root = v:FindFirstChild("HumanoidRootPart") or v.PrimaryPart
            if hum and root and hum.Health > 0 and root:IsA("BasePart") then
                if charRoot then
                    local d = (root.Position - charRoot.Position).Magnitude
                    if d <= maxRange then
                        table.insert(npcs, { model = v, root = root, hum = hum })
                    end
                else
                    table.insert(npcs, { model = v, root = root, hum = hum })
                end
            end
        end
    end
    return npcs
end

local function buildZoneMap(npcs, charRootPos)
    local zones = {}
    for _, npc in ipairs(npcs) do
        local key = getZoneKey(npc.root.Position)
        if not zones[key] then
            zones[key] = { npcs = {}, center = Vector3.new(0, 0, 0), count = 0 }
        end
        table.insert(zones[key].npcs, npc)
        zones[key].center = zones[key].center + npc.root.Position
        zones[key].count = zones[key].count + 1
    end
    for _, z in pairs(zones) do
        z.center = z.center / z.count
        z.distFromStart = (z.center - charRootPos).Magnitude
    end
    return zones
end

local function getSortedZoneKeys(zones)
    local keys = {}
    for k, _ in pairs(zones) do table.insert(keys, k) end
    table.sort(keys, function(a, b) return zones[a].distFromStart < zones[b].distFromStart end)
    return keys
end

