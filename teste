-- FLY MANUAL (TOGGLE SEPARADO)
-- =========================================================================
local bv, bg
local function getCharacterParts()
    local char = LocalPlayer.Character
    if char then
        return char, char:FindFirstChild("HumanoidRootPart"), char:FindFirstChild("Humanoid")
    end
    return nil, nil, nil
end

function iniciarFly()
    local char, rootPart, humanoid = getCharacterParts()
    if not char or not rootPart or not humanoid then return end
    
    if not bv then
        bv = Instance.new("BodyVelocity")
        bv.MaxForce = Vector3.new(1e6, 1e6, 1e6)
    end
    if not bg then
        bg = Instance.new("BodyGyro")
        bg.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
        bg.P = 20000
    end
    
    bv.Parent = rootPart
    bg.Parent = rootPart
    humanoid.PlatformStand = true
    
    -- Noclip
    if Connections.FlyNoclip then Connections.FlyNoclip:Disconnect() end
    Connections.FlyNoclip = RunService.Stepped:Connect(function()
        if NightHub.FlyAtivo and char then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
    end)
    
    -- Movimento manual
    if Connections.FlyMovement then Connections.FlyMovement:Disconnect() end
    Connections.FlyMovement = RunService.Heartbeat:Connect(function()
        if not NightHub.FlyAtivo then return end
        pcall(function()
            local _, rp, _ = getCharacterParts()
            if not rp then return end
            
            local camera = workspace.CurrentCamera
            local moveDir = Vector3.new(0, 0, 0)
            
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + camera.CFrame.RightVector end
            
            if moveDir.Magnitude > 0 then
                bv.Velocity = moveDir.Unit * NightHub.FlySpeed
            else
                bv.Velocity = Vector3.new(0, 0.1, 0)
            end
            
            bg.CFrame = CFrame.new(rp.Position, rp.Position + Vector3.new(camera.CFrame.LookVector.X, 0, camera.CFrame.LookVector.Z))
        end)
    end)
end

function pararFly()
    NightHub.FlyAtivo = false
    
    if bv and not NightHub.FarmAtivo then
        bv.Velocity = Vector3.new(0, 0, 0)
        bv.Parent = nil
    end
    if bg and not NightHub.FarmAtivo then
        bg.Parent = nil
    end
    
    pcall(function()
        local _, _, humanoid = getCharacterParts()
        if humanoid and not NightHub.FarmAtivo then
            humanoid.PlatformStand = false
        end
    end)
    
    if Connections.FlyNoclip then Connections.FlyNoclip:Disconnect(); Connections.FlyNoclip = nil end
    if Connections.FlyMovement then Connections.FlyMovement:Disconnect(); Connections.FlyMovement = nil end
end

-- =========================================================================
-- VOID-STALKER FARM (COM DETECÇÃO DE VOIDSHADE - ANDA PARA A FRENTE)
-- =========================================================================
local farmFlying = false
local currentTarget = nil
local currentTargetModel = nil
local isCurrentVoidShade = false
local orbitAngle = 0
local currentBoss = nil
local bossLastSeen = 0
local BossPositions = {
    ["Adelys"] = { pos = Vector3.new(1585, -487, 98), cooldown = 8 },
    ["The Voidborn"] = { pos = Vector3.new(2352, -621, 87), cooldown = 10 },
}
local farmChar, farmRoot, farmHum

local function updateFarmChar()
    local char = LocalPlayer.Character
    if char then
        farmChar = char
        farmRoot = char:FindFirstChild("HumanoidRootPart")
        farmHum = char:FindFirstChild("Humanoid")
        return true
    end
    return false
end

local function getBestPart(model)
    local target = model:FindFirstChild("HumanoidRootPart") or 
                   model:FindFirstChild("Torso") or 
                   model:FindFirstChild("LowerTorso") or 
                   model:FindFirstChild("UpperTorso") or 
                   model.PrimaryPart or 
                   model:FindFirstChildWhichIsA("BasePart")
    if target and target:IsA("BasePart") then return target end
    if target and target:IsA("Model") then return target:FindFirstChildWhichIsA("BasePart") end
    return nil
end

local function isVoidShade(name)
    local n = string.lower(name)
    return string.find(n, "voidshade") or string.find(n, "void shade")
end

function iniciarFarm()
    if not updateFarmChar() then return end
    
    if not bv then
        bv = Instance.new("BodyVelocity")
        bv.MaxForce = Vector3.new(1e6, 1e6, 1e6)
    end
    if not bg then
        bg = Instance.new("BodyGyro")
        bg.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
        bg.P = 20000
    end
    
    farmFlying = true
    bv.Parent = farmRoot
    bg.Parent = farmRoot
    farmHum.PlatformStand = true
    
    -- Noclip
    if Connections.FarmNoclip then Connections.FarmNoclip:Disconnect() end
    Connections.FarmNoclip = RunService.Stepped:Connect(function()
        if farmFlying and farmChar then
            for _, part in pairs(farmChar:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
    end)
    
    -- Busca de Alvo (detecta VoidShades e Gregg)
    local targetSearchRunning = true
    local greggFound = false
    local orbitWasAuto = false
    if Connections.FarmTargetSearch then Connections.FarmTargetSearch:Disconnect() end
    Connections.FarmTargetSearch = task.spawn(function()
        while targetSearchRunning and NightHub.FarmAtivo do
            pcall(function()
                if not updateFarmChar() then return end
                
                local bossFound = false
                local closestNormal = nil
                local closestNormalModel = nil
                local closestVoid = nil
                local closestVoidModel = nil
                local closestGregg = nil
                local closestGreggModel = nil
                local shortestNormal = NightHub.MaxDetectionRange
                local shortestVoid = NightHub.MaxDetectionRange
                local shortestGregg = NightHub.MaxDetectionRange
                
                for _, v in pairs(workspace:GetDescendants()) do
                    if v:IsA("Humanoid") and v.Parent ~= farmChar and v.Health > 0 then
                        local model = v.Parent
                        local targetPart = getBestPart(model)
                        if targetPart and targetPart:IsA("BasePart") then
                            local d = (targetPart.Position - farmRoot.Position).Magnitude
                            local nameLower = string.lower(model.Name)
                            
                            if string.find(nameLower, "adelys") then
                                currentBoss = "Adelys"
                                bossFound = true
                                bossLastSeen = tick()
                            elseif string.find(nameLower, "the voidborn") then
                                currentBoss = "The Voidborn"
                                bossFound = true
                                bossLastSeen = tick()
                            elseif string.find(nameLower, "gregg") then
                                if d < shortestGregg then
                                    shortestGregg = d
                                    closestGregg = targetPart
                                    closestGreggModel = model
                                end
                            elseif isVoidShade(model.Name) then
                                if d < shortestVoid then
                                    shortestVoid = d
                                    closestVoid = targetPart
                                    closestVoidModel = model
                                end
                            else
                                if d < shortestNormal then
                                    shortestNormal = d
                                    closestNormal = targetPart
                                    closestNormalModel = model
                                end
                            end
                        end
                    end
                end
                
                -- Boss cooldown: manter posicao por Xs apos boss morrer
                if not bossFound and currentBoss then
                    local cd = BossPositions[currentBoss] and BossPositions[currentBoss].cooldown or 4
                    if (tick() - bossLastSeen) >= cd then
                        currentBoss = nil
                    else
                        currentTarget = nil
                        currentTargetModel = nil
                        isCurrentVoidShade = false
                        return
                    end
                end
                
                -- Gregg tem prioridade máxima
                if closestGregg then
                    if not greggFound then
                        greggFound = true
                        orbitWasAuto = not NightHub.OrbitMode
                        NightHub.OrbitMode = true
                    end
                    currentTarget = closestGregg
                    currentTargetModel = closestGreggModel
                    isCurrentVoidShade = false
                else
                    -- Gregg morreu ou desapareceu, desativa orbit auto
                    if greggFound then
                        greggFound = false
                        if orbitWasAuto then
                            NightHub.OrbitMode = false
                            orbitWasAuto = false
                        end
                    end
                    if closestNormal then
                        currentTarget = closestNormal
                        currentTargetModel = closestNormalModel
                        isCurrentVoidShade = false
                    elseif closestVoid then
                        currentTarget = closestVoid
                        currentTargetModel = closestVoidModel
                        isCurrentVoidShade = true
                    end
                end
            end)
            task.wait(0.3)
        end
    end)
    
    -- Hitbox
    local hitboxRunning = true
    if Connections.FarmHitbox then Connections.FarmHitbox:Disconnect() end
    Connections.FarmHitbox = task.spawn(function()
        while hitboxRunning and NightHub.FarmAtivo do
            pcall(function()
                for _, v in pairs(workspace:GetDescendants()) do
                    if v:IsA("Humanoid") and v.Parent ~= farmChar then
                        local targetPart = getBestPart(v.Parent)
                        if targetPart and targetPart:IsA("BasePart") and targetPart.Size.Y < NightHub.HitboxSize then
                            targetPart.Size = Vector3.new(NightHub.HitboxSize, NightHub.HitboxSize, NightHub.HitboxSize)
                            targetPart.Transparency = 1
                            targetPart.CanCollide = false
                        end
                    end
                end
            end)
            task.wait(2)
        end
    end)
    
    -- Loop de Movimento
    if Connections.FarmMovement then Connections.FarmMovement:Disconnect() end
    Connections.FarmMovement = RunService.Heartbeat:Connect(function()
        if not farmFlying or not NightHub.FarmAtivo then return end
        
        pcall(function()
            if not updateFarmChar() then return end
            
            local goToBoss = false
            if currentBoss and BossPositions[currentBoss] then
                if currentTarget and currentTarget:IsA("BasePart") and currentTarget.Parent then
                    goToBoss = false
                else
                    goToBoss = true
                end
            end

            if goToBoss then
                local bossPos = BossPositions[currentBoss].pos
                local direction = (bossPos - farmRoot.Position)
                if direction.Magnitude > 2 then
                    bv.Velocity = direction.Unit * NightHub.FlightSpeed
                else
                    bv.Velocity = Vector3.new(0, 0, 0)
                end
                bg.CFrame = CFrame.new(farmRoot.Position, Vector3.new(bossPos.X, farmRoot.Position.Y, bossPos.Z))
            elseif currentTarget and currentTarget:IsA("BasePart") and currentTarget.Parent then
                local targetPos = currentTarget.Position
                
                if NightHub.OrbitMode then
                    -- ORBIT MODE: gira ao redor de qualquer NPC
                    orbitAngle = orbitAngle + 0.02
                    local orbitRadius = 8
                    local orbitX = math.cos(orbitAngle) * orbitRadius
                    local orbitZ = math.sin(orbitAngle) * orbitRadius
                    local orbitPos = targetPos + Vector3.new(orbitX, 0, orbitZ)
                    
                    local direction = (orbitPos - farmRoot.Position)
                    if direction.Magnitude > 1 then
                        bv.Velocity = direction.Unit * NightHub.FlightSpeed
                    else
                        bv.Velocity = Vector3.new(0, 0, 0)
                    end
                    
                    bg.CFrame = CFrame.new(farmRoot.Position, Vector3.new(targetPos.X, farmRoot.Position.Y, targetPos.Z))
                elseif isCurrentVoidShade and currentTargetModel then
                    -- VOIDSHADE: fica atrás dele, desvia quando ele olha para ti
                    local voidLook = currentTarget.CFrame.LookVector
                    local toPlayer = (farmRoot.Position - targetPos)
                    toPlayer = Vector3.new(toPlayer.X, 0, toPlayer.Z)
                    if toPlayer.Magnitude > 0.1 then
                        toPlayer = toPlayer.Unit
                    else
                        toPlayer = Vector3.new(0, 0, -1)
                    end
                    
                    local dot = voidLook:Dot(toPlayer)
                    
                    local backPos
                    if dot > 0.3 then
                        local behind = -voidLook
                        backPos = targetPos + behind * 15
                    else
                        local behind = -voidLook
                        backPos = targetPos + behind * 15
                    end
                    
                    local direction = (backPos - farmRoot.Position)
                    if direction.Magnitude > 1 then
                        bv.Velocity = direction.Unit * NightHub.FlightSpeed
                    else
                        bv.Velocity = Vector3.new(0, 0, 0)
                    end
                    
                    bg.CFrame = CFrame.new(farmRoot.Position, Vector3.new(targetPos.X, farmRoot.Position.Y, targetPos.Z))
                else
                    -- NPC normal: vai underground
                    local undergroundPos = Vector3.new(targetPos.X, targetPos.Y + NightHub.FixedDepth, targetPos.Z)
                    local direction = (undergroundPos - farmRoot.Position)
                    
                    if direction.Magnitude > 1 then
                        bv.Velocity = direction.Unit * NightHub.FlightSpeed
                    else
                        bv.Velocity = Vector3.new(0, 0, 0)
                    end
                    
                    bg.CFrame = CFrame.new(farmRoot.Position, Vector3.new(targetPos.X, farmRoot.Position.Y, targetPos.Z))
                end
            else
                orbitAngle = 0
                local forward = farmRoot.CFrame.LookVector
                bv.Velocity = Vector3.new(forward.X, 0, forward.Z).Unit * (NightHub.FlightSpeed * 0.7)
            end
        end)
    end)
end

function pararFarm()
    farmFlying = false
    currentTarget = nil
    currentTargetModel = nil
    isCurrentVoidShade = false
    currentBoss = nil
    orbitAngle = 0
    NightHub.FarmAtivo = false
    
    if bv and not NightHub.FlyAtivo then
        bv.Velocity = Vector3.new(0, 0, 0)
        bv.Parent = nil
    end
    if bg and not NightHub.FlyAtivo then
