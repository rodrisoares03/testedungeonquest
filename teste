local function getBestPart(model)
    local target = model:FindFirstChild("HumanoidRootPart") or
                   model:FindFirstChild("Torso") or
                   model:FindFirstChild("LowerTorso") or
                   model:FindFirstChild("UpperTorso") or
                   model.PrimaryPart or
                   model:FindFirstChildWhichIsA("BasePart")
    if target and target:IsA("BasePart") then return target end
    if target and target:IsA("Model") then return target:FindFirstChildWhichIsA("BasePart") end
    return nil
end

local function isVoidShade(name)
    local n = string.lower(name)
    return string.find(n, "voidshade") or string.find(n, "void shade")
end

function iniciarLeapingStrikeTP()
    if Connections.LeapingStrikeTP then return end

    local tpBV = Instance.new("BodyVelocity")
    tpBV.MaxForce = Vector3.new(1e6, 1e6, 1e6)
    tpBV.P = 10000
    tpBV.Velocity = Vector3.new(0, 0, 0)

    local tpBG = Instance.new("BodyGyro")
    tpBG.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
    tpBG.P = 10000

    Connections.LeapingStrikeTP = task.spawn(function()
        while NightHub.LeapingStrikeTPAtivo do
            pcall(function()
                local char = LocalPlayer.Character
                local rootPart = char and char:FindFirstChild("HumanoidRootPart")
                if not rootPart then return end

                tpBV.Parent = rootPart
                tpBG.Parent = rootPart

                local closestNPC = nil
                local closestDist = math.huge
                local closestNPCModel = nil
                local isVoidShadeTarget = false
                local bossName = nil

                for _, v in pairs(workspace:GetDescendants()) do
                    if v:IsA("Humanoid") and v.Parent ~= char and v.Health > 0 then
                        local model = v.Parent
                        local targetPart = getBestPart(model)
                        if targetPart and targetPart:IsA("BasePart") then
                            local d = (targetPart.Position - rootPart.Position).Magnitude
                            local nameLower = string.lower(model.Name)

                            if string.find(nameLower, "adelys") then
                                bossName = "Adelys"
                                closestNPC = targetPart
                                closestNPCModel = model
                                closestDist = d
                            elseif string.find(nameLower, "the voidborn") then
                                bossName = "The Voidborn"
                                closestNPC = targetPart
                                closestNPCModel = model
                                closestDist = d
                            elseif isVoidShade(model.Name) then
                                if d < closestDist then
                                    closestDist = d
                                    closestNPC = targetPart
                                    closestNPCModel = model
                                    isVoidShadeTarget = true
                                    bossName = nil
                                end
                            else
                                if d < closestDist and not bossName then
                                    closestDist = d
                                    closestNPC = targetPart
                                    closestNPCModel = model
                                    isVoidShadeTarget = false
                                    bossName = nil
                                end
                            end
                        end
                    end
                end

                local npcAlive = false
                if closestNPC and closestNPCModel then
                    local hum = closestNPCModel:FindFirstChildOfClass("Humanoid")
                    if hum and hum.Health > 0 and closestNPC.Parent and closestNPCModel.Parent then
                        npcAlive = true
                    end
                end

                if npcAlive then
                    tpBV.Velocity = Vector3.new(0, 0, 0)

                    if bossName == "Adelys" then
                        rootPart.CFrame = CFrame.new(closestNPC.Position)

                    elseif bossName == "The Voidborn" then
                        rootPart.CFrame = CFrame.new(closestNPC.Position)

                    elseif isVoidShadeTarget and closestNPC then
                        local voidLook = closestNPC.CFrame.LookVector
                        local toPlayer = (rootPart.Position - closestNPC.Position)
                        toPlayer = Vector3.new(toPlayer.X, 0, toPlayer.Z)
                        if toPlayer.Magnitude > 0.1 then
                            toPlayer = toPlayer.Unit
                        else
                            toPlayer = Vector3.new(0, 0, -1)
                        end

                        local behind = -voidLook
                        local backPos = closestNPC.Position + behind * 15
                        rootPart.CFrame = CFrame.new(backPos, closestNPC.Position)

                    elseif closestNPC and closestDist > 8 then
                        local behind = -closestNPC.CFrame.LookVector
                        local backPos = closestNPC.Position + behind * 10
                        rootPart.CFrame = CFrame.new(backPos, closestNPC.Position)
                    end
                else
                    tpBV.Velocity = Vector3.new(0, 0.5, 0)
                    tpBG.CFrame = CFrame.new(rootPart.Position, rootPart.Position + rootPart.CFrame.LookVector)
                end
            end)
            task.wait(0.1)
        end
    end)

    Connections.LeapingStrikeTPCleanup = function()
        if tpBV then tpBV:Destroy() end
        if tpBG then tpBG:Destroy() end
    end
end

function pararLeapingStrikeTP()
    NightHub.LeapingStrikeTPAtivo = false
    currentZoneMap = nil
    currentZoneKeys = nil
    if Connections.LeapingStrikeTPCleanup then
        pcall(Connections.LeapingStrikeTPCleanup)
        Connections.LeapingStrikeTPCleanup = nil
    end
    if Connections.LeapingStrikeTP then
        pcall(task.cancel, Connections.LeapingStrikeTP)
        Connections.LeapingStrikeTP = nil
    end
end

