function iniciarChanger()
    local asset = "rbxassetid://103879899072630"
    local function isAvatarImage(label)
        local img = label.Image
        if typeof(img) == "string" and img ~= "" then
            if string.find(img, tostring(LocalPlayer.UserId)) then return true end
            if string.find(img, "rbxthumb://") and (string.find(string.lower(img), "avatar") or string.find(string.lower(img), "headshot") or string.find(string.lower(img), "bust")) then return true end
        end
        local name = string.lower(label.Name)
        if name == "avatar" or name == "portrait" or name == "playericon" or name == "avatarimage" or name == "charicon" or name == "charactericon" then return true end
        if label.Parent then
            local pName = string.lower(label.Parent.Name)
            if pName == "avatar" or pName == "portrait" or pName == "playerframe" or pName == "avatarframe" or pName == "charframe" or pName == "portraitframe" then return true end
        end
        return false
    end
    local function applyToLabel(label)
        if label:IsA("ImageLabel") or label:IsA("ImageButton") then
            local function check()
                if typeof(label.Image) == "string" and label.Image ~= asset and isAvatarImage(label) then label.Image = asset end
            end
            check()
            label:GetPropertyChangedSignal("Image"):Connect(check)
        end
    end
    local playerGui = LocalPlayer:WaitForChild("PlayerGui")
    for _, descendant in ipairs(playerGui:GetDescendants()) do pcall(applyToLabel, descendant) end
    playerGui.DescendantAdded:Connect(function(descendant) task.wait(); pcall(applyToLabel, descendant) end)
end

