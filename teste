_G[NIGHTHUB_ID].ApplyConfig = function(configData)
    pcall(function()
        applySnapshot(configData)
        refreshAllTextLabels()
        for catKey, rarMap in pairs(AutoSellSettings) do
            for rarKey, _ in pairs(rarMap) do
                atualizarBotaoRaridade(catKey, rarKey)
            end
        end
    end)
end

