function applySnapshot(data)
    if type(data) ~= "table" then return end
    
    -- Primeiro as variáveis de dados
    if data.OcultarNome ~= nil then NightHub.OcultarNome = data.OcultarNome end
    if data.NomePersonalizado ~= nil then NightHub.NomePersonalizado = data.NomePersonalizado end
    if data.VelocidadeExtra ~= nil then NightHub.VelocidadeExtra = data.VelocidadeExtra end
    if data.NoVFXAtivo ~= nil then NightHub.NoVFXAtivo = data.NoVFXAtivo end
    if data.FlightSpeed ~= nil then NightHub.FlightSpeed = data.FlightSpeed end
    if data.FlySpeed ~= nil then NightHub.FlySpeed = data.FlySpeed end
    if data.OrbitMode ~= nil then NightHub.OrbitMode = data.OrbitMode end
    if data.FixedDepth ~= nil then NightHub.FixedDepth = data.FixedDepth end
    if data.MaxDetectionRange ~= nil then NightHub.MaxDetectionRange = data.MaxDetectionRange end
    if data.HitboxSize ~= nil then NightHub.HitboxSize = data.HitboxSize end
    
    if type(data.AutoSellSettings) == "table" then
        for cat, rarities in pairs(data.AutoSellSettings) do
            if AutoSellSettings[cat] then
                for rar, val in pairs(rarities) do
                    if AutoSellSettings[cat][rar] ~= nil then
                        AutoSellSettings[cat][rar] = val
                    end
                end
            end
        end
    end

    if type(data.Binds) == "table" then
        for k, v in pairs(data.Binds) do
            if Binds[k] ~= nil then Binds[k] = v end
        end
    end

    -- Aplicar estados de toggle
    if data.SpammerAtivo ~= nil then
        NightHub.SpammerAtivo = data.SpammerAtivo
        UpdateUIToggle("Spammer", NightHub.SpammerAtivo)
        if NightHub.SpammerAtivo then pcall(iniciarSpammer) else pcall(pararSpammer) end
    end
    if data.FarmAtivo ~= nil then
        NightHub.FarmAtivo = data.FarmAtivo
        UpdateUIToggle("Farm", NightHub.FarmAtivo)
        if NightHub.FarmAtivo then pcall(iniciarFarm) else pcall(pararFarm) end
    end
    if data.FlyAtivo ~= nil then
        NightHub.FlyAtivo = data.FlyAtivo
        UpdateUIToggle("Fly", NightHub.FlyAtivo)
        if NightHub.FlyAtivo then pcall(iniciarFly) else pcall(pararFly) end
    end
    if data.AutoSellAtivo ~= nil then
        NightHub.AutoSellAtivo = data.AutoSellAtivo
        UpdateUIToggle("AutoSell", NightHub.AutoSellAtivo)
        if NightHub.AutoSellAtivo then
            pcall(function()
                local autoSell = loadstring(game:HttpGet('https://raw.githubusercontent.com/ValorantIsKewl/RBX/refs/heads/main/DQautoSell.lua'))()
                autoSell(AutoSellSettings)
            end)
        end
    end
    if data.AutoRetryAtivo ~= nil then
        NightHub.AutoRetryAtivo = data.AutoRetryAtivo
        UpdateUIToggle("AutoRetry", NightHub.AutoRetryAtivo)
        if NightHub.AutoRetryAtivo then
            pcall(function()
                loadstring(game:HttpGet('https://raw.githubusercontent.com/ValorantIsKewl/RBX/refs/heads/main/DQAutoRetry'))()
            end)
        end
    end
    if data.AutoStartAtivo ~= nil then
        NightHub.AutoStartAtivo = data.AutoStartAtivo
        UpdateUIToggle("AutoStart", NightHub.AutoStartAtivo)
        if NightHub.AutoStartAtivo then pcall(iniciarAutoStart) else pcall(pararAutoStart) end
    end
    if data.NoVFXAtivo ~= nil then
        UpdateUIToggle("NoVFX", data.NoVFXAtivo)
        if data.NoVFXAtivo then pcall(ativarNoVFX) else pcall(desativarNoVFX) end
    end
    if data.VelocidadeExtra ~= nil then
        UpdateUIToggle("Speed", data.VelocidadeExtra)
        if data.VelocidadeExtra then pcall(ativarVelocidadeExtra) else pcall(desativarVelocidadeExtra) end
    end
    
    -- Atualiza visual dos botões de raridade na aba Sell
    for catKey, _ in pairs(AutoSellSettings) do
        for rarKey, _ in pairs(AutoSellSettings[catKey]) do
            atualizarBotaoRaridade(catKey, rarKey)
        end
    end
    
    refreshAllTextLabels()
end

