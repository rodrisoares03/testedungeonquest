        if _G.NightHubConfigLoadstring and type(_G.NightHubConfigLoadstring) == "string" then
            print("[NightHub] Config loadstring detectado, a processar...")
            local configStr = _G.NightHubConfigLoadstring
            _G.NightHubConfigLoadstring = nil -- limpar para não repetir
            local ok, cfgFunc = pcall(loadstring, configStr)
            if ok and cfgFunc then
                local ok2, cfg = pcall(cfgFunc)
                if ok2 and type(cfg) == "table" then
                    print("[NightHub] Config decodificada com sucesso, a aplicar...")
                    for _, v in pairs(_G) do
                        if type(v) == "table" and v.ApplyConfig then
                            v.ApplyConfig(cfg)
                            print("[NightHub] Config importada via loadstring!")
                            return -- PARAR o loop
                        end
                    end
                else
                    print("[NightHub] Erro ao decodificar config:", ok2, cfg)
                end
            else
                print("[NightHub] Erro ao executar loadstring:", ok, cfgFunc)
            end
        end

        -- Formato 2: _G.Config é tabela direta
        if _G.Config and type(_G.Config) == "table" then
            local cfg = _G.Config
            _G.Config = nil
            for _, v in pairs(_G) do
                if type(v) == "table" and v.ApplyConfig then
                    v.ApplyConfig(cfg)
                    print("[NightHub] Config importada via _G.Config!")
                    return
                end
            end
        end

        -- Formato 3: _G.NightHubConfigPending
        if _G.NightHubConfigPending and type(_G.NightHubConfigPending) == "table" then
            local cfg = _G.NightHubConfigPending
            _G.NightHubConfigPending = nil
            for _, v in pairs(_G) do
                if type(v) == "table" and v.ApplyConfig then
                    v.ApplyConfig(cfg)
                    print("[NightHub] Config importada!")
                    return
                end
            end
        end

        task.wait(0.25)
    end
end)
