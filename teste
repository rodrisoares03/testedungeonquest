-- SPAMMER (HEARTBEAT + TOOL:ACTIVATE + VIM CLICKS)
-- =========================================================================
local LeapingStrikeUsedOnce = false
local VIM = game:GetService("VirtualInputManager")
local ForceClickActive = false
local LeapingStrikeAutoUsed = false

local function usarLeapingStrikeUmaVez()
    if LeapingStrikeAutoUsed then return end
    local char = LocalPlayer.Character
    if not char then return end
    local ls = char:FindFirstChild("Leaping Strike")
    if not (ls and ls:IsA("Tool")) then return end
    LeapingStrikeAutoUsed = true
    pcall(function()
        VIM:SendKeyEvent(true, Enum.KeyCode.E, false, game)
        task.wait(0.05)
        VIM:SendKeyEvent(false, Enum.KeyCode.E, false, game)
    end)
end

function forceClickQ()
    ForceClickActive = true
    task.spawn(function()
        pcall(function()
            local vim = game:GetService("VirtualInputManager")
            vim:SendKeyEvent(true, Enum.KeyCode.E, false, game)
            task.wait(0.05)
            vim:SendKeyEvent(false, Enum.KeyCode.E, false, game)
        end)
    end)
    task.delay(0.2, function() ForceClickActive = false end)
end

function iniciarSpammer()
    if Connections.SpamLoop then return end
    LeapingStrikeUsedOnce = false
    LeapingStrikeAutoUsed = false

    task.defer(function()
        for _ = 1, 20 do
            if not NightHub.SpammerAtivo then return end
            usarLeapingStrikeUmaVez()
            if LeapingStrikeAutoUsed then return end
            task.wait(0.1)
        end
    end)

    Connections.SpamLoop = RunService.Heartbeat:Connect(function()
        if not NightHub.SpammerAtivo then return end

        pcall(function()
            local char = LocalPlayer.Character
            if not char then return end
            local bp = LocalPlayer:FindFirstChild("Backpack")

            -- Desativa animações de tools para não causar pausas
            for _, tool in ipairs(char:GetChildren()) do
                if tool:IsA("Tool") and tool.Name ~= "Leaping Strike" then
                    pcall(function()
                        local humanoid = char:FindFirstChildOfClass("Humanoid")
                        if humanoid then
                            local animator = humanoid:FindFirstChildOfClass("Animator")
                            if animator then
                                for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
                                    if track and track.IsPlaying then
                                        track:Stop(0)
                                    end
                                end
                            end
                        end
                    end)
                end
            end

            -- Spam Q key (dano)
            pcall(function()
                VIM:SendKeyEvent(true, Enum.KeyCode.Q, false, game)
                task.defer(function()
                    VIM:SendKeyEvent(false, Enum.KeyCode.Q, false, game)
                end)
            end)

            -- Spam E key (cura)
            pcall(function()
                VIM:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                task.defer(function()
                    VIM:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                end)
            end)

            local tools = {}
            for _, v in ipairs(char:GetChildren()) do
                if v:IsA("Tool") then table.insert(tools, v) end
            end
            if bp then
                for _, v in ipairs(bp:GetChildren()) do
                    if v:IsA("Tool") then table.insert(tools, v) end
                end
            end

            for _, tool in ipairs(tools) do
                pcall(function()
                    if tool.Name ~= "Leaping Strike" then
                        -- Desativa animação da tool
                        pcall(function()
                            for _, obj in ipairs(tool:GetDescendants()) do
                                if obj:IsA("AnimationTrack") then
                                    obj:Stop(0)
                                end
                            end
                        end)

                        if tool.Parent == char then
                            tool:Activate()
                        end

                        -- Fire RemoteEvents diretamente (bypass animação)
                        for _, d in ipairs(tool:GetDescendants()) do
                            if d:IsA("RemoteEvent") then
                                d:FireServer()
                            end
                        end
                    end
                end)
            end
        end)
    end)
end

function pararSpammer()
    if Connections.SpamLoop then
        Connections.SpamLoop:Disconnect()
        Connections.SpamLoop = nil
        NightHub.SpammerAtivo = false
    end
end

-- =========================================================================
-- FLY MANUAL (TOGGLE SEPARADO)
-- =========================================================================
local bv, bg
local function getCharacterParts()
    local char = LocalPlayer.Character
    if char then
        return char, char:FindFirstChild("HumanoidRootPart"), char:FindFirstChild("Humanoid")
    end
    return nil, nil, nil
end

function iniciarFly()
    local char, rootPart, humanoid = getCharacterParts()
    if not char or not rootPart or not humanoid then return end
    
    if not bv then
        bv = Instance.new("BodyVelocity")
        bv.MaxForce = Vector3.new(1e6, 1e6, 1e6)
    end
    if not bg then
        bg = Instance.new("BodyGyro")
        bg.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
        bg.P = 20000
    end
    
    bv.Parent = rootPart
    bg.Parent = rootPart
    humanoid.PlatformStand = true
    
    -- Noclip
    if Connections.FlyNoclip then Connections.FlyNoclip:Disconnect() end
    Connections.FlyNoclip = RunService.Stepped:Connect(function()
        if NightHub.FlyAtivo and char then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
    end)
    
    -- Movimento manual
    if Connections.FlyMovement then Connections.FlyMovement:Disconnect() end
    Connections.FlyMovement = RunService.Heartbeat:Connect(function()
        if not NightHub.FlyAtivo then return end
        pcall(function()
            local _, rp, _ = getCharacterParts()
            if not rp then return end
            
            local camera = workspace.CurrentCamera
            local moveDir = Vector3.new(0, 0, 0)
            
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + camera.CFrame.RightVector end
            
            if moveDir.Magnitude > 0 then
                bv.Velocity = moveDir.Unit * NightHub.FlySpeed
            else
                bv.Velocity = Vector3.new(0, 0.1, 0)
            end
            
            bg.CFrame = CFrame.new(rp.Position, rp.Position + Vector3.new(camera.CFrame.LookVector.X, 0, camera.CFrame.LookVector.Z))
        end)
    end)
end

function pararFly()
    NightHub.FlyAtivo = false
    
    if bv and not NightHub.FarmAtivo then
        bv.Velocity = Vector3.new(0, 0, 0)
        bv.Parent = nil
    end
    if bg and not NightHub.FarmAtivo then
        bg.Parent = nil
    end
    
    pcall(function()
        local _, _, humanoid = getCharacterParts()
        if humanoid and not NightHub.FarmAtivo then
            humanoid.PlatformStand = false
        end
    end)
    
    if Connections.FlyNoclip then Connections.FlyNoclip:Disconnect(); Connections.FlyNoclip = nil end
    if Connections.FlyMovement then Connections.FlyMovement:Disconnect(); Connections.FlyMovement = nil end
end

-- =========================================================================
-- VOID-STALKER FARM (COM DETECÇÃO DE VOIDSHADE - ANDA PARA A FRENTE)
-- =========================================================================
local farmFlying = false
local currentTarget = nil
local currentTargetModel = nil
local isCurrentVoidShade = false
local orbitAngle = 0
local currentBoss = nil
local bossLastSeen = 0
local farmChar, farmRoot, farmHum

local function updateFarmChar()
    local char = LocalPlayer.Character
    if char then
        farmChar = char
        farmRoot = char:FindFirstChild("HumanoidRootPart")
        farmHum = char:FindFirstChild("Humanoid")
        return true
    end
    return false
end

function iniciarFarm()
    if not updateFarmChar() then return end
    
    if not bv then
        bv = Instance.new("BodyVelocity")
        bv.MaxForce = Vector3.new(1e6, 1e6, 1e6)
    end
    if not bg then
        bg = Instance.new("BodyGyro")
        bg.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
        bg.P = 20000
    end
    
    farmFlying = true
    bv.Parent = farmRoot
    bg.Parent = farmRoot
    farmHum.PlatformStand = true
    
    -- Noclip
    if Connections.FarmNoclip then Connections.FarmNoclip:Disconnect() end
    Connections.FarmNoclip = RunService.Stepped:Connect(function()
        if farmFlying and farmChar then
            for _, part in pairs(farmChar:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
    end)
    
    -- Busca de Alvo (detecta VoidShades e Gregg)
    local targetSearchRunning = true
    local greggFound = false
    local orbitWasAuto = false
    local lastFarmScanTime = 0
    local FARM_SCAN_INTERVAL = 0.2
    if Connections.FarmTargetSearch then Connections.FarmTargetSearch:Disconnect() end
    Connections.FarmTargetSearch = task.spawn(function()
        while targetSearchRunning and NightHub.FarmAtivo do
            pcall(function()
                if not updateFarmChar() then return end

                local now = tick()
                if now - lastFarmScanTime < FARM_SCAN_INTERVAL then
                    task.wait(0.05)
                    return
                end
                lastFarmScanTime = now
                
                local bossFound = false
                local closestNormal = nil
                local closestNormalModel = nil
                local closestVoid = nil
                local closestVoidModel = nil
                local closestGregg = nil
                local closestGreggModel = nil
                local shortestNormal = NightHub.MaxDetectionRange
                local shortestVoid = NightHub.MaxDetectionRange
                local shortestGregg = NightHub.MaxDetectionRange
                
                for _, v in pairs(workspace:GetDescendants()) do
                    if v:IsA("Humanoid") and v.Parent ~= farmChar and v.Health > 0 then
                        local model = v.Parent
                        local targetPart = getBestPart(model)
                        if targetPart and targetPart:IsA("BasePart") then
                            local d = (targetPart.Position - farmRoot.Position).Magnitude
                            local nameLower = string.lower(model.Name)
                            
                            if string.find(nameLower, "adelys") then
                                currentBoss = "Adelys"
                                bossFound = true
                                bossLastSeen = tick()
                            elseif string.find(nameLower, "the voidborn") then
                                currentBoss = "The Voidborn"
                                bossFound = true
                                bossLastSeen = tick()
                            elseif string.find(nameLower, "gregg") then
                                if d < shortestGregg then
                                    shortestGregg = d
                                    closestGregg = targetPart
                                    closestGreggModel = model
                                end
                            elseif isVoidShade(model.Name) then
                                if d < shortestVoid then
                                    shortestVoid = d
                                    closestVoid = targetPart
                                    closestVoidModel = model
                                end
                            else
                                if d < shortestNormal then
                                    shortestNormal = d
                                    closestNormal = targetPart
                                    closestNormalModel = model
                                end
                            end
                        end
                    end
                end
                
                -- Boss cooldown: manter posicao por Xs apos boss morrer
                if not bossFound and currentBoss then
                    local cd = BossPositions[currentBoss] and BossPositions[currentBoss].cooldown or 4
                    if (tick() - bossLastSeen) >= cd then
                        currentBoss = nil
                    else
                        currentTarget = nil
                        currentTargetModel = nil
                        isCurrentVoidShade = false
                        return
                    end
                end
                
                -- Gregg tem prioridade máxima
                if closestGregg then
                    if not greggFound then
                        greggFound = true
                        orbitWasAuto = not NightHub.OrbitMode
                        NightHub.OrbitMode = true
                    end
                    currentTarget = closestGregg
                    currentTargetModel = closestGreggModel
                    isCurrentVoidShade = false
                else
                    -- Gregg morreu ou desapareceu, desativa orbit auto
                    if greggFound then
                        greggFound = false
                        if orbitWasAuto then
                            NightHub.OrbitMode = false
                            orbitWasAuto = false
                        end
                    end
                    if closestNormal then
                        currentTarget = closestNormal
                        currentTargetModel = closestNormalModel
                        isCurrentVoidShade = false
                    elseif closestVoid then
                        currentTarget = closestVoid
                        currentTargetModel = closestVoidModel
                        isCurrentVoidShade = true
                    end
                end
            end)
            task.wait(0.3)
        end
    end)
    
    -- Hitbox
    local hitboxRunning = true
    if Connections.FarmHitbox then Connections.FarmHitbox:Disconnect() end
    Connections.FarmHitbox = task.spawn(function()
        while hitboxRunning and NightHub.FarmAtivo do
            pcall(function()
                for _, v in pairs(workspace:GetDescendants()) do
                    if v:IsA("Humanoid") and v.Parent ~= farmChar then
                        local targetPart = getBestPart(v.Parent)
                        if targetPart and targetPart:IsA("BasePart") and targetPart.Size.Y < NightHub.HitboxSize then
                            targetPart.Size = Vector3.new(NightHub.HitboxSize, NightHub.HitboxSize, NightHub.HitboxSize)
                            targetPart.Transparency = 1
                            targetPart.CanCollide = false
                        end
                    end
                end
            end)
            task.wait(2)
        end
    end)
    
    -- Loop de Movimento
    if Connections.FarmMovement then Connections.FarmMovement:Disconnect() end
    Connections.FarmMovement = RunService.Heartbeat:Connect(function()
        if not farmFlying or not NightHub.FarmAtivo then return end
        
        pcall(function()
            if not updateFarmChar() then return end
            
            local goToBoss = false
            if currentBoss and BossPositions[currentBoss] then
                if currentTarget and currentTarget:IsA("BasePart") and currentTarget.Parent then
                    goToBoss = false
                else
                    goToBoss = true
                end
            end

            if goToBoss then
                local bossPos = BossPositions[currentBoss].pos
                local direction = (bossPos - farmRoot.Position)
                if direction.Magnitude > 2 then
                    bv.Velocity = direction.Unit * NightHub.FlightSpeed
                else
                    bv.Velocity = Vector3.new(0, 0, 0)
                end
                bg.CFrame = CFrame.new(farmRoot.Position, Vector3.new(bossPos.X, farmRoot.Position.Y, bossPos.Z))
            elseif currentTarget and currentTarget:IsA("BasePart") and currentTarget.Parent then
                local targetPos = currentTarget.Position
                
                if NightHub.OrbitMode then
                    -- ORBIT MODE: gira ao redor de qualquer NPC
                    orbitAngle = orbitAngle + 0.02
                    local orbitRadius = 8
                    local orbitX = math.cos(orbitAngle) * orbitRadius
                    local orbitZ = math.sin(orbitAngle) * orbitRadius
                    local orbitPos = targetPos + Vector3.new(orbitX, 0, orbitZ)
                    
                    local direction = (orbitPos - farmRoot.Position)
                    if direction.Magnitude > 1 then
                        bv.Velocity = direction.Unit * NightHub.FlightSpeed
                    else
                        bv.Velocity = Vector3.new(0, 0, 0)
                    end
                    
                    bg.CFrame = CFrame.new(farmRoot.Position, Vector3.new(targetPos.X, farmRoot.Position.Y, targetPos.Z))
                elseif isCurrentVoidShade and currentTargetModel then
                    -- VOIDSHADE: fica atrás dele, desvia quando ele olha para ti
                    local voidLook = currentTarget.CFrame.LookVector
                    local toPlayer = (farmRoot.Position - targetPos)
                    toPlayer = Vector3.new(toPlayer.X, 0, toPlayer.Z)
                    if toPlayer.Magnitude > 0.1 then
                        toPlayer = toPlayer.Unit
                    else
                        toPlayer = Vector3.new(0, 0, -1)
                    end
                    
                    local dot = voidLook:Dot(toPlayer)
                    
                    local backPos
                    if dot > 0.3 then
                        local behind = -voidLook
                        backPos = targetPos + behind * 15
                    else
                        local behind = -voidLook
                        backPos = targetPos + behind * 15
                    end
                    
                    local direction = (backPos - farmRoot.Position)
                    if direction.Magnitude > 1 then
                        bv.Velocity = direction.Unit * NightHub.FlightSpeed
                    else
                        bv.Velocity = Vector3.new(0, 0, 0)
                    end
                    
                    bg.CFrame = CFrame.new(farmRoot.Position, Vector3.new(targetPos.X, farmRoot.Position.Y, targetPos.Z))
                else
                    -- NPC normal: vai underground
                    local undergroundPos = Vector3.new(targetPos.X, targetPos.Y + NightHub.FixedDepth, targetPos.Z)
                    local direction = (undergroundPos - farmRoot.Position)
                    
                    if direction.Magnitude > 1 then
                        bv.Velocity = direction.Unit * NightHub.FlightSpeed
                    else
                        bv.Velocity = Vector3.new(0, 0, 0)
                    end
                    
                    bg.CFrame = CFrame.new(farmRoot.Position, Vector3.new(targetPos.X, farmRoot.Position.Y, farmRoot.Position.Z))
                end
            else
                -- Sem alvo: ficar no mesmo nível, NÃO ir underground
                orbitAngle = 0
                local currentY = farmRoot.Position.Y
                local targetY = currentY
                -- Manter altitude segura (acima do underground)
                if targetY < -10 then targetY = -5 end
                local safePos = Vector3.new(farmRoot.Position.X, targetY, farmRoot.Position.Z)
                local direction = (safePos - farmRoot.Position)
                if direction.Magnitude > 1 then
                    bv.Velocity = direction.Unit * (NightHub.FlightSpeed * 0.5)
                else
                    bv.Velocity = Vector3.new(0, 0.5, 0)
                end
                bg.CFrame = CFrame.new(farmRoot.Position, farmRoot.Position + farmRoot.CFrame.LookVector)
            end
        end)
    end)
end

function pararFarm()
    farmFlying = false
    currentTarget = nil
    currentTargetModel = nil
    isCurrentVoidShade = false
    currentBoss = nil
    orbitAngle = 0
    NightHub.FarmAtivo = false
    
    if bv and not NightHub.FlyAtivo then
        bv.Velocity = Vector3.new(0, 0, 0)
        bv.Parent = nil
    end
    if bg and not NightHub.FlyAtivo then
        bg.Parent = nil
    end
    
    pcall(function()
        if updateFarmChar() and not NightHub.FlyAtivo then
            farmHum.PlatformStand = false
        end
    end)
    
    if Connections.FarmNoclip then Connections.FarmNoclip:Disconnect(); Connections.FarmNoclip = nil end
    if Connections.FarmTargetSearch then pcall(task.cancel, Connections.FarmTargetSearch); Connections.FarmTargetSearch = nil end
    if Connections.FarmHitbox then pcall(task.cancel, Connections.FarmHitbox); Connections.FarmHitbox = nil end
    if Connections.FarmMovement then Connections.FarmMovement:Disconnect(); Connections.FarmMovement = nil end
end

-- =========================================================================
-- NoVFX
-- =========================================================================
-- NoVFX (MODO FPS BAIXO - desativa efeitos mas mantém chão/rendering)
-- =========================================================================
local NoVFXObjects = {}
local NoVFXOriginalMaterials = {}

local function isGroundOrTerrain(obj)
    -- Não mexer no chão/terrain/parts que afetam colisão
    if obj:IsA("Terrain") then return true end
    if obj:IsA("BasePart") then
        local name = string.lower(obj.Name)
        if string.find(name, "floor") or string.find(name, "ground") or string.find(name, "terrain") 
            or string.find(name, "base") or string.find(name, "spawn") or string.find(name, "platform") then
            return true
        end
    end
    return false
end

local function disableVFX(obj)
    if not NightHub.NoVFXAtivo then return end
    pcall(function()
        local className = obj.ClassName

        -- Partículas e efeitos visuais
        if className == "ParticleEmitter" or className == "Trail" or className == "Beam" 
            or className == "Fire" or className == "Smoke" or className == "Sparkles"
            or className == "Explosion" or className == "SpotLight" or className == "PointLight"
            or className == "SurfaceLight" or className == "ShurikenEmitter" then
            obj.Enabled = false
            if obj:IsA("Trail") then obj.LightInfluence = 0; obj.Transparency = NumberSequence.new(1) end
            if obj:IsA("Beam") then obj.Transparency = NumberSequence.new(1) end
            table.insert(NoVFXObjects, obj)

        -- Sons
        elseif className == "Sound" then
            obj.Volume = 0
            table.insert(NoVFXObjects, obj)

        -- UI 3D
        elseif className == "SurfaceGui" or className == "BillboardGui" then
            local name = string.lower(obj.Name)
            if not (string.find(name, "hp") or string.find(name, "health") or string.find(name, "name")) then
                obj.Enabled = false
                table.insert(NoVFXObjects, obj)
            end

        -- Decals/texturas que são efeitos
        elseif className == "Decal" or className == "Texture" then
            local parent = obj.Parent
            if parent and parent:IsA("BasePart") then
                local pname = string.lower(parent.Name)
                -- Não remover texturas do chão/paredes, só de efeitos
                if not (string.find(pname, "floor") or string.find(pname, "wall") or string.find(pname, "ground") or string.find(pname, "spawn")) then
                    obj.Transparency = 1
                    table.insert(NoVFXObjects, obj)
                end
            end
        end
    end)
end

function ativarNoVFX()
    if Connections.VFX then Connections.VFX:Disconnect() end

    -- 1. Desativar partículas/sons/efeitos visuais
    for _, obj in ipairs(workspace:GetDescendants()) do
        disableVFX(obj)
    end

    -- 2. Novos efeitos também são desativados
    Connections.VFX = workspace.DescendantAdded:Connect(disableVFX)

    -- 3. Desativar sombras e efeitos de lighting (só fps, sem mexer nas cores)
    pcall(function()
        local lighting = game:GetService("Lighting")
        lighting.GlobalShadows = false
        lighting.EnvironmentDiffuseScale = 0
        lighting.EnvironmentSpecularScale = 0

        for _, effect in ipairs(lighting:GetDescendants()) do
            if effect:IsA("Atmosphere") or effect:IsA("Sky") or effect:IsA("BloomEffect")
                or effect:IsA("ColorCorrectionEffect") or effect:IsA("SunRaysEffect")
                or effect:IsA("BlurEffect") or effect:IsA("DepthOfFieldEffect") then
                effect.Enabled = false
                table.insert(NoVFXObjects, effect)
            end
        end
    end)

    print("[NoVFX] Efeitos visuais desativados!")
end

function desativarNoVFX()
    for _, obj in ipairs(NoVFXObjects) do
        pcall(function()
            if obj and obj.Parent then
                if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam")
                    or obj:IsA("Fire") or obj:IsA("Smoke") or obj:IsA("Sparkles")
                    or obj:IsA("SpotLight") or obj:IsA("PointLight") or obj:IsA("SurfaceLight") then
                    obj.Enabled = true
                elseif obj:IsA("Sound") then
                    obj.Volume = 0.5
                elseif obj:IsA("Atmosphere") or obj:IsA("Sky") or obj:IsA("BloomEffect")
                    or obj:IsA("ColorCorrectionEffect") or obj:IsA("SunRaysEffect")
                    or obj:IsA("BlurEffect") or obj:IsA("DepthOfFieldEffect") then
                    obj.Enabled = true
                elseif obj:IsA("SurfaceGui") or obj:IsA("BillboardGui") or obj:IsA("ScreenGui") then
                    obj.Enabled = true
                end
            end
        end)
    end
    NoVFXObjects = {}

    pcall(function()
        local lighting = game:GetService("Lighting")
        lighting.GlobalShadows = true
        lighting.EnvironmentDiffuseScale = 1
        lighting.EnvironmentSpecularScale = 1
    end)

    if Connections.VFX then Connections.VFX:Disconnect(); Connections.VFX = nil end

    print("[NoVFX] Modo normal restaurado!")
end

