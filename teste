local function isHabilidade(nome)
    nome = string.upper(nome)
    for _, k in ipairs({"PULSE","LIGHTNING","MAGIC","EFFECT","SPELL","ATTACK","BOMB","EXPLOSION","BLAST","FIRE","ICE","THUNDER","STORM","WIND","EARTH","WATER","SHADOW","LIGHT","DARK","HOLY","DEMON","DRAGON","PHOENIX","WOLF","SKILL","POWER","BURST","SLASH","CUT","STAB"}) do
        if string.match(nome, k) then return true end
    end
    return false
end

function ativarNoVFX()
    if Connections.VFX then Connections.VFX:Disconnect() end
    Connections.VFX = workspace.DescendantAdded:Connect(function(obj)
        if not NightHub.NoVFXAtivo then return end
        pcall(function()
            if isHabilidade(obj.Name) or (obj.Parent and isHabilidade(obj.Parent.Name)) then
                if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") or obj:IsA("Fire") or obj:IsA("Smoke") then 
                    obj.Enabled = false
                elseif obj:IsA("Sound") then 
                    obj.Volume = 0 
                end
            end
        end)
    end)
end

function desativarNoVFX()
    if Connections.VFX then Connections.VFX:Disconnect(); Connections.VFX = nil end
end

