_G[NIGHTHUB_ID].Cleanup = function()
    -- Desativa todas as funções
    ForceClickActive = false
    pcall(function() if NightHub.SpammerAtivo then pararSpammer() end end)
    pcall(function() if NightHub.FlyAtivo then pararFly() end end)
    pcall(function() if NightHub.FarmAtivo then pararFarm() end end)
    pcall(function() if NightHub.NoVFXAtivo then desativarNoVFX() end end)
    pcall(function() if NightHub.VelocidadeExtra then desativarVelocidadeExtra() end end)
    pcall(function() if NightHub.AutoStartAtivo then pararAutoStart() end end)
    pcall(function() if NightHub.LeapingStrikeTPAtivo then pararLeapingStrikeTP() end end)
    
    -- Desconecta todas as conexões
    for _, conn in ipairs(Connections) do
        pcall(function() conn:Disconnect() end)
    end
    Connections = {}
    
    -- Remove a GUI
    pcall(function() ScreenGui:Destroy() end)
    
    -- Marca como inativo
    _G[NIGHTHUB_ID].Active = false
end

