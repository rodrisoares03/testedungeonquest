-- =========================================================================
-- SISTEMA DE CORREÇÃO DE NOMES (NAME CHANGER / HIDER)
-- =========================================================================
local MatchedTextLabels = {}
local defaultDisplayName = LocalPlayer.DisplayName
local defaultName = LocalPlayer.Name

function applyToTextLabel(label)
    if not label:IsA("TextLabel") and not label:IsA("TextBox") then return end
    if MatchedTextLabels[label] then return end
    
    local txt = label.Text
    local isMatch = string.upper(txt) == string.upper(defaultDisplayName) or 
                    string.upper(txt) == string.upper(defaultName)
                    
    if isMatch then
        local data = { OriginalText = txt, Connection = nil, Updating = false }
        MatchedTextLabels[label] = data
        local function check()
            if data.Updating then return end
            local currentText = label.Text
            local targetText = data.OriginalText
            if NightHub.OcultarNome then targetText = ""
            elseif NightHub.NomePersonalizado ~= "" then targetText = NightHub.NomePersonalizado end
            if currentText ~= targetText then
                data.Updating = true
                label.Text = targetText
                data.Updating = false
            end
        end
        data.Connection = label:GetPropertyChangedSignal("Text"):Connect(check)
        check()
    end
end

function refreshAllTextLabels()
    for label, data in pairs(MatchedTextLabels) do
        pcall(function()
            if data.Updating then return end
            local targetText = data.OriginalText
            if NightHub.OcultarNome then targetText = ""
            elseif NightHub.NomePersonalizado ~= "" then targetText = NightHub.NomePersonalizado end
            if label.Text ~= targetText then
                data.Updating = true
                label.Text = targetText
                data.Updating = false
            end
        end)
    end
end

function iniciarNameChanger()
    local playerGui = LocalPlayer:WaitForChild("PlayerGui")
    local function scan(root) for _, descendant in ipairs(root:GetDescendants()) do pcall(applyToTextLabel, descendant) end end
    scan(playerGui)
    playerGui.DescendantAdded:Connect(function(descendant) task.wait(); pcall(applyToTextLabel, descendant) end)
    local function monitorCharacter(char) if not char then return end scan(char) char.DescendantAdded:Connect(function(descendant) task.wait(); pcall(applyToTextLabel, descendant) end) end
    monitorCharacter(LocalPlayer.Character)
    LocalPlayer.CharacterAdded:Connect(monitorCharacter)
end

