function iniciarSpammer()
    if Connections.SpamLoop then return end
    Connections.SpamLoop = RunService.Heartbeat:Connect(function()
        if not NightHub.SpammerAtivo then return end
        pcall(function()
            local char = LocalPlayer.Character
            if not char then return end
            
            local tools = {}
            for _, v in ipairs(char:GetChildren()) do if v:IsA("Tool") then table.insert(tools, v) end end
            local bp = LocalPlayer:FindFirstChild("Backpack")
            if bp then for _, v in ipairs(bp:GetChildren()) do if v:IsA("Tool") then table.insert(tools, v) end end end
            
            for _, tool in ipairs(tools) do
                pcall(function()
                    if tool.Parent == char then tool:Activate() end
                    for _, d in ipairs(tool:GetDescendants()) do
                        if d:IsA("RemoteEvent") then d:FireServer() end
                    end
                end)
            end
        end)
    end)
end

function pararSpammer()
    if Connections.SpamLoop then
        Connections.SpamLoop:Disconnect()
        Connections.SpamLoop = nil
        NightHub.SpammerAtivo = false
    end
end

