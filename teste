function getAllConfigs()
    local ok, exists = pcall(isfile, configsFileName)
    if not ok or not exists then return {} end
    local ok2, content = pcall(readfile, configsFileName)
    if not ok2 or not content then return {} end
    local ok3, data = pcall(function() return HttpService:JSONDecode(content) end)
    if not ok3 or type(data) ~= "table" then return {} end
    return data
end

local function resolveDungeonStartRemote(waitSeconds)
    local deadline = os.clock() + math.max(0, waitSeconds or 0)

    while true do
        local remote = ReplicatedStorage:FindFirstChild("changeStartValue", true)
        if remote and remote:IsA("RemoteEvent") then
            return remote
        end

        local remotes = ReplicatedStorage:FindFirstChild("remotes") or ReplicatedStorage:FindFirstChild("Remotes")
        if remotes then
            remote = remotes:FindFirstChild("changeStartValue", true)
            if remote and remote:IsA("RemoteEvent") then
                return remote
            end
        end

        if waitSeconds == nil or os.clock() >= deadline then
            return nil
        end

        task.wait(0.2)
    end
end

local ePressedOnStart = false

local function fireDungeonStart(waitSeconds)
    local remote = resolveDungeonStartRemote(waitSeconds or 0)
    if not remote then
        warn("Remote 'changeStartValue' not found!")
        return false
    end

    local ok = pcall(function()
        remote:FireServer()
    end)

    if ok then
        NightHub.DungeonStartCount = NightHub.DungeonStartCount + 1
        if counterLabel then
            counterLabel.Text = "Runs: " .. tostring(NightHub.DungeonStartCount)
        end
        return true
    end

    warn("Falha ao disparar o remote 'changeStartValue'")
    return false
end

local function clickAt(x, y)
    pcall(function()
        if mousemoveabs then
            mousemoveabs(x, y)
            task.wait(0.02)
            mouse1click()
        elseif mousemove then
            mousemove(x, y)
            task.wait(0.02)
            mouse1click()
        else
            local vim = game:GetService("VirtualInputManager")
            vim:SendMouseMoveEvent(x, y, game)
            task.wait(0.02)
            vim:SendMouseButtonEvent(x, y, 0, true, game, 1, nil)
            task.wait(0.01)
            vim:SendMouseButtonEvent(x, y, 0, false, game, 1, nil)
        end
    end)
end

