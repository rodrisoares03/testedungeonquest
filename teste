    -- Clica no Q para desbugar a ability
    task.wait(0.5)
    pcall(function()
        local char = LocalPlayer.Character
        if not char then return end
        local backpack = LocalPlayer:FindFirstChild("Backpack")
        -- Procura a ability de dano (slot Q) e ativa
        if backpack then
            for _, tool in ipairs(backpack:GetChildren()) do
                if tool:IsA("Tool") and tool.Name ~= "Leaping Strike" then
                    local isHeal = false
                    for _, healName in ipairs(NightHub.SupportedHeals) do
                        if tool.Name == healName then isHeal = true; break end
                    end
                    if not isHeal then
                        tool.Parent = char
                        task.wait(0.2)
                        tool:Activate()
                        task.wait(0.3)
                        tool.Parent = backpack
                        print("[Init] Q ability ativada para desbugar!")
                        break
                    end
                end
            end
        end
    end)

    -- Auto-setup de habilidades (Q=Damage, E=Heal)
    task.wait(1)
    pcall(setupAbilities)
end)

